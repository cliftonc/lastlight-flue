# --- Secrets (never commit) ---
secrets/
.env
.env.*
!.env.example
*.pem
*.key
*.private-key.*

# --- Node / build ---
node_modules/
# Build output (`flue build` → ./dist/server.mjs). Root-scoped so it does NOT
# ignore the committed prebuilt dashboard assets at `dashboard/dist/`.
/dist/
*.tsbuildinfo
.flue/
.flue-vite/
coverage/

# --- Local state / runtime ---
*.db
*.db-journal
*.sqlite
# Runtime SQLite stores live in a dot-directory so `flue dev`'s file watcher
# ignores them — the app writes these DBs while running, and watching them
# caused a rebuild→restart→write loop. Dot-dirs are ignored by the watcher.
.data/
logs/
.DS_Store

# --- Editor ---
.idea/
.vscode/

# --- Claude Code harness (local) ---
.claude/
data/
